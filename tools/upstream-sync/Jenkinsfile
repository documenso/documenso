def notifyTeams(String title, String text, String color) {
    try {
        withCredentials([string(credentialsId: 'teams-webhook-url', variable: 'TEAMS_WEBHOOK_URL')]) {
            sh(script: """
                curl -s -X POST "\${TEAMS_WEBHOOK_URL}" \
                    -H "Content-Type: application/json" \
                    -d '{
                        "title": "${title}",
                        "text": "${text}",
                        "themeColor": "${color}"
                    }'
            """, returnStatus: true)
        }
    } catch (Exception e) {
        echo "Teams notification skipped (credential 'teams-webhook-url' not configured): ${e.message}"
    }
}

pipeline {
    agent { label 'dev-jenkinsrunner-01.davincisolutions.ai' }

    options {
        buildDiscarder(logRotator(numToKeepStr: '30'))
        timeout(time: 45, unit: 'MINUTES')
        timestamps()
    }

    triggers {
        cron('H 6 * * *')
    }

    parameters {
        string(name: 'UPSTREAM_REF', defaultValue: '', description: 'Specific upstream ref to sync (tag, SHA, or branch). Leave empty for upstream/main HEAD.')
        booleanParam(name: 'FORCE_CLAUDE', defaultValue: false, description: 'Force AI resolution even when merge is clean (useful for branding drift detection)')
        booleanParam(name: 'DRY_RUN', defaultValue: false, description: 'Run the full pipeline without pushing or creating PRs')
        booleanParam(name: 'ENABLE_TSC', defaultValue: false, description: 'Enable TypeScript validation via Docker (requires Docker on agent)')
    }

    environment {
        OPENROUTER_API_KEY  = credentials('openrouter-api-key')
        OPENROUTER_MODEL    = 'google/gemini-3-flash-preview'
        UPSTREAM_URL        = 'https://github.com/documenso/documenso.git'
        FORK_REPO           = 'Davinci-Technology/documenso'
    }

    stages {
        stage('Setup') {
            steps {
                checkout([
                    $class: 'GitSCM',
                    branches: [[name: '*/main']],
                    extensions: [
                        [$class: 'CloneOption', depth: 0, shallow: false],
                        [$class: 'SubmoduleOption', disableSubmodules: true]
                    ],
                    userRemoteConfigs: [[
                        url: "https://github.com/${FORK_REPO}.git"
                    ]]
                ])
                sh '''
                    git config user.email "ci@davincisolutions.ai"
                    git config user.name "Davinci CI"

                    # Configure upstream remote
                    git remote get-url upstream 2>/dev/null || git remote add upstream "${UPSTREAM_URL}"
                    git fetch upstream --quiet
                    git fetch origin --quiet

                    # Create Python venv and install deps
                    python3 -m venv .venv
                    . .venv/bin/activate
                    pip install --quiet -r tools/upstream-sync/requirements.txt
                '''
            }
        }

        stage('Detect Changes') {
            steps {
                script {
                    def upstreamRef = params.UPSTREAM_REF?.trim() ? params.UPSTREAM_REF.trim() : 'upstream/main'

                    def mergeBase = sh(
                        script: "git merge-base origin/main ${upstreamRef}",
                        returnStdout: true
                    ).trim()

                    def commitCount = sh(
                        script: "git rev-list --count ${mergeBase}..${upstreamRef}",
                        returnStdout: true
                    ).trim().toInteger()

                    echo "Merge base: ${mergeBase}"
                    echo "Upstream commits since last sync: ${commitCount}"

                    if (commitCount == 0 && !params.FORCE_CLAUDE) {
                        echo "No upstream changes detected. Nothing to sync."
                        env.SKIP_SYNC = 'true'
                    } else {
                        env.SKIP_SYNC = 'false'
                        env.MERGE_BASE = mergeBase
                        env.UPSTREAM_REF = upstreamRef
                        env.COMMIT_COUNT = commitCount.toString()

                        def today = sh(script: 'date +%Y-%m-%d', returnStdout: true).trim()
                        env.SYNC_BRANCH = "upstream-sync/${today}"

                        sh 'mkdir -p sync-output'
                        sh "git diff --name-only ${mergeBase}..${upstreamRef} > sync-output/changed_files.txt"

                        echo "Sync branch will be: ${env.SYNC_BRANCH}"
                    }
                }
            }
        }

        stage('Attempt Merge') {
            when {
                expression { env.SKIP_SYNC != 'true' }
            }
            steps {
                script {
                    // Clean up any leftover sync branch from a previous run
                    sh "git branch -D ${env.SYNC_BRANCH} 2>/dev/null || true"
                    sh "git checkout -b ${env.SYNC_BRANCH} origin/main"

                    def mergeResult = sh(
                        script: "git merge ${env.UPSTREAM_REF} --no-edit",
                        returnStatus: true
                    )

                    if (mergeResult == 0) {
                        echo "Merge completed cleanly."
                        env.MERGE_CLEAN = 'true'
                    } else {
                        echo "Merge has conflicts."
                        env.MERGE_CLEAN = 'false'
                        sh 'git diff --name-only --diff-filter=U > sync-output/conflicted_files.txt'
                    }

                    sh '''
                        . .venv/bin/activate
                        python3 -c "
import yaml, pathlib, fnmatch

config = yaml.safe_load(pathlib.Path('tools/upstream-sync/config.yaml').read_text())
changed = pathlib.Path('sync-output/changed_files.txt').read_text().strip().splitlines()

branding_patterns = (
    config['classification']['branding_only_patterns'] +
    config['classification']['branding_text_patterns']
)

touched = []
for f in changed:
    for pat in branding_patterns:
        if fnmatch.fnmatch(f, pat):
            touched.append(f)
            break

pathlib.Path('sync-output/branding_touched.txt').write_text('\\n'.join(touched))
print(f'Branding files touched by upstream: {len(touched)}')
for t in touched:
    print(f'  - {t}')
"
                    '''

                    def brandingCount = sh(
                        script: 'wc -l < sync-output/branding_touched.txt',
                        returnStdout: true
                    ).trim().toInteger()

                    env.BRANDING_FILES_TOUCHED = (brandingCount > 0) ? 'true' : 'false'
                    echo "Branding files touched: ${brandingCount}"
                }
            }
        }

        stage('Resolve Conflicts') {
            when {
                allOf {
                    expression { env.SKIP_SYNC != 'true' }
                    expression {
                        env.MERGE_CLEAN != 'true' ||
                        env.BRANDING_FILES_TOUCHED == 'true' ||
                        params.FORCE_CLAUDE
                    }
                }
            }
            steps {
                script {
                    def tscFlag = params.ENABLE_TSC ? '--enable-tsc' : ''

                    // The resolver handles the full tier escalation + repair loop internally.
                    // Exit code 0 = all resolved, 1 = unresolvable files, 2 = fatal error.
                    def rc = sh(script: """
                        . .venv/bin/activate
                        PYTHONPATH=tools/upstream-sync python3 -m branding_resolver \
                            --repo . \
                            --our-branch origin/main \
                            --upstream-branch upstream/main \
                            --output-pr-body sync-output/pr_body.md \
                            --tier1-model "\${OPENROUTER_MODEL}" \
                            --tier2-model "anthropic/claude-sonnet-4" \
                            --tier3-model "anthropic/claude-opus-4" \
                            --max-repair-rounds 3 \
                            ${tscFlag} \
                            --verbose
                    """, returnStatus: true)

                    if (rc == 2) {
                        error "Branding resolver failed with fatal error (exit 2)"
                    }

                    // Read the unresolvable files list (the merge gate).
                    if (fileExists('sync-output/unresolvable_files.txt')) {
                        env.UNRESOLVABLE = readFile('sync-output/unresolvable_files.txt').trim()
                    } else {
                        env.UNRESOLVABLE = ''
                    }

                    // Read confidence for logging.
                    if (fileExists('sync-output/confidence.txt')) {
                        env.CONFIDENCE = readFile('sync-output/confidence.txt').trim()
                        echo "Confidence score (informational): ${env.CONFIDENCE}"
                    }

                    // Log resolution report.
                    if (fileExists('sync-output/resolution_report.json')) {
                        def report = readFile('sync-output/resolution_report.json')
                        echo "Resolution report:\n${report}"
                    }

                    // Finalize the merge commit.
                    sh 'git reset HEAD -- .venv sync-output 2>/dev/null || true'
                    sh 'git checkout -- .venv 2>/dev/null || true'
                    sh 'git add -A -- . ":!.venv" ":!sync-output"'
                    sh 'git commit --no-edit || true'
                }
            }
        }

        stage('Create PR and Merge') {
            when {
                allOf {
                    expression { env.SKIP_SYNC != 'true' }
                    expression { !params.DRY_RUN }
                }
            }
            steps {
                // All git/gh operations need the GitHub App token.
                withCredentials([usernamePassword(
                    credentialsId: 'github-app-davinci',
                    usernameVariable: 'GIT_USER',
                    passwordVariable: 'GIT_PASS'
                )]) {
                script {
                    def unresolvable = (env.UNRESOLVABLE ?: '').trim()
                    def mergeClean = (env.MERGE_CLEAN == 'true')
                    def agentRan = (env.BRANDING_FILES_TOUCHED == 'true' || !mergeClean || params.FORCE_CLAUDE)

                    // Set GITHUB_TOKEN for gh CLI and push URL for git.
                    env.GITHUB_TOKEN = env.GIT_PASS
                    sh """
                        git remote set-url origin https://\${GIT_USER}:\${GIT_PASS}@github.com/${FORK_REPO}.git
                        git push origin ${env.SYNC_BRANCH} --force
                    """

                    // Close any existing PR for this sync branch.
                    sh(script: "gh pr close ${env.SYNC_BRANCH} --repo ${FORK_REPO} 2>/dev/null || true", returnStatus: true)

                    if (unresolvable.isEmpty()) {
                        // All files resolved — create PR and auto-merge.
                        echo "All files resolved. Creating PR and auto-merging."

                        def prBody = ''
                        if (fileExists('sync-output/pr_body.md')) {
                            prBody = readFile('sync-output/pr_body.md')
                        } else {
                            prBody = "Automated upstream sync from ${env.UPSTREAM_REF}.\n\nCommits: ${env.COMMIT_COUNT}\nAll conflicts resolved automatically."
                        }

                        writeFile file: 'sync-output/gh_pr_body.md', text: prBody

                        sh """
                            gh pr create \
                                --repo ${FORK_REPO} \
                                --base main \
                                --head ${env.SYNC_BRANCH} \
                                --title "chore: upstream sync ${env.SYNC_BRANCH}" \
                                --body-file sync-output/gh_pr_body.md
                        """

                        def prUrl = sh(
                            script: "gh pr view ${env.SYNC_BRANCH} --repo ${FORK_REPO} --json url -q .url",
                            returnStdout: true
                        ).trim()

                        // Auto-merge the PR.
                        def mergeResult = sh(
                            script: "gh pr merge ${env.SYNC_BRANCH} --repo ${FORK_REPO} --merge --admin",
                            returnStatus: true
                        )

                        if (mergeResult == 0) {
                            echo "PR auto-merged successfully: ${prUrl}"
                            notifyTeams("Upstream Sync Auto-Merged",
                                "Branch **${env.SYNC_BRANCH}** merged to main via PR.\\n\\nCommits synced: ${env.COMMIT_COUNT}\\n[View PR](${prUrl})",
                                "00CC00")
                        } else {
                            // Fallback: enable auto-merge flag for when checks pass.
                            echo "Direct merge failed (branch protection). Enabling auto-merge."
                            sh(script: "gh pr merge ${env.SYNC_BRANCH} --repo ${FORK_REPO} --merge --auto", returnStatus: true)
                            notifyTeams("Upstream Sync PR Created (Auto-Merge Enabled)",
                                "Branch **${env.SYNC_BRANCH}** PR created with auto-merge enabled.\\n\\nCommits: ${env.COMMIT_COUNT}\\n[Review PR](${prUrl})",
                                "00CC00")
                        }

                    } else {
                        // Some files unresolvable — create draft PR for review.
                        echo "Unresolvable files detected. Creating draft PR for review."
                        echo "Unresolvable: ${unresolvable}"

                        def prBody = ''
                        if (fileExists('sync-output/pr_body.md')) {
                            prBody = readFile('sync-output/pr_body.md')
                        } else {
                            prBody = "Automated upstream sync from ${env.UPSTREAM_REF}.\n\nCommits: ${env.COMMIT_COUNT}\n\n**Unresolvable files:**\n${unresolvable}"
                        }

                        writeFile file: 'sync-output/gh_pr_body.md', text: prBody

                        sh """
                            gh pr create \
                                --repo ${FORK_REPO} \
                                --base main \
                                --head ${env.SYNC_BRANCH} \
                                --title "chore: upstream sync ${env.SYNC_BRANCH}" \
                                --body-file sync-output/gh_pr_body.md \
                                --draft
                        """

                        def prUrl = sh(
                            script: "gh pr view ${env.SYNC_BRANCH} --repo ${FORK_REPO} --json url -q .url",
                            returnStdout: true
                        ).trim()

                        // Post inline review comments on flagged files.
                        if (fileExists('sync-output/flagged_reviews.json')) {
                            sh(script: '''
                                . .venv/bin/activate
                                PYTHONPATH=tools/upstream-sync python3 -m branding_resolver.post_review
                                gh pr comment ${SYNC_BRANCH} \
                                    --repo ${FORK_REPO} \
                                    --body-file sync-output/review_comment.md
                            ''', returnStatus: true)
                        }

                        notifyTeams("Upstream Sync PR Created (Draft — Needs Review)",
                            "Branch **${env.SYNC_BRANCH}** has unresolvable files.\\n\\nCommits: ${env.COMMIT_COUNT}\\n[Review PR](${prUrl})",
                            "FFA500")
                    }
                }
                } // withCredentials
            }
        }
    }

    post {
        failure {
            node('dev-jenkinsrunner-01.davincisolutions.ai') {
                notifyTeams("Upstream Sync FAILED",
                    "Pipeline failed at stage: ${env.STAGE_NAME}\\n\\nBuild: ${env.BUILD_URL}",
                    "FF0000")
            }
        }
    }
}
